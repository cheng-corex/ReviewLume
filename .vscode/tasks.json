{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "options": {
        "cwd": "${workspaceFolder}/apps/vscode-extension"
      },
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}

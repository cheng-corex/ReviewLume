{
  "name": "reviewlume",
  "private": true,
  "version": "0.1.0",
  "description": "Privacy-first, read-only-first, multi-web-AI-compatible code review assistant",
  "license": "MIT",
  "author": "ReviewLume contributors",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm -r test",
    "validate:browser-extension": "node browser-extension/scripts/validate.mjs",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "package:vscode": "pnpm --filter reviewlume-vscode package",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@10.33.0"
}
